# --- core ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- database ---
# postgres+asyncpg in production; sqlite+aiosqlite is fine for local dev/tests.
DATABASE_URL=postgresql+asyncpg://monad:monad@localhost:5432/monad_intel
DATABASE_ECHO=false

# --- redis ---
REDIS_URL=redis://localhost:6379/0

# --- monad chain ---
MONAD_CHAIN=monad
MONAD_CHAIN_ID=143
# Comma-separated list; the RPC client round-robins on failure.
MONAD_RPC_HTTP=https://rpc.monad.xyz,https://rpc1.monad.xyz,https://rpc2.monad.xyz
MONAD_RPC_WS=wss://rpc.monad.xyz
# "newHeads" (Voted, reorg-free, default) or "monadNewHeads" (Proposed, speculative).
MONAD_WS_SUBSCRIPTION=newHeads
RPC_TIMEOUT_SECONDS=15
RPC_MAX_RETRIES=4
RECEIPT_RETRY_ATTEMPTS=8
RECEIPT_RETRY_BASE_MS=120

# --- ingestion ---
BOOTSTRAP_CHUNK_SIZE=50
BLOCK_QUEUE_MAXSIZE=512
ENRICHMENT_CONCURRENCY=8

# --- verification ---
SOURCIFY_BASE_URL=https://sourcify-api-monad.blockvision.org
ETHERSCAN_V2_BASE_URL=https://api.etherscan.io/v2/api
ETHERSCAN_API_KEY=

# --- Fortytwo Prime (ENABLED) ---
# Two ways to authenticate, in priority order:
#   1. Platform wallet + x402Escrow (no API key) — PLATFORM_WALLET_PRIVATE_KEY set.
#   2. Legacy API key — FORTYTWO_API_KEY set.
# If neither is set, manager.py falls back to LocalProvider (no charge, no external calls).
FORTYTWO_PRIME_ENABLED=true

# --- MCP / x402 path (preferred) ---
FORTYTWO_MCP_URL=https://mcp.fortytwo.network/mcp
FORTYTWO_MCP_PROTOCOL_VERSION=2025-11-25
FORTYTWO_MCP_CLIENT_NAME=monad-scope
FORTYTWO_MCP_CLIENT_VERSION=0.1.0
FORTYTWO_TOOL_NAME=ask_fortytwo_prime

# --- Platform wallet ---
# Hex private key (with or without 0x). Hold >= 2 USDC on the configured chain.
# Empty = MCP path disabled.
PLATFORM_WALLET_PRIVATE_KEY=
# "monad" (chain 143) or "base" (chain 8453).
PLATFORM_WALLET_CHAIN=monad
# Per-request x402 payment cap in USDC base units (6 decimals). Default = 2 USDC.
FORTYTWO_MAX_PAYMENT_USDC_UNITS=2000000

# Contracts (Fortytwo-supported defaults).
USDC_MONAD_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603
USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
FORTYTWO_ESCROW_RECIPIENT=0x9562f50f73d8ee22276f13a18d051456d8d137a0

# --- Legacy API-key path (fallback) ---
FORTYTWO_API_BASE_URL=https://api.fortytwo.network/v1
FORTYTWO_API_KEY=
FORTYTWO_MODEL=fortytwo-prime
FORTYTWO_TIMEOUT_SECONDS=120
FORTYTWO_MAX_TOKENS=4096

# --- billing ---
PRIME_PRICE_USD=6
PRIME_LOCK_TTL_SECONDS=60

# --- Privy (user wallet auth) ---
# Frontend uses @privy-io/react-auth with PRIVY_APP_ID. Backend verifies the
# Privy access token (JWT) against Privy's JWKS. The App Secret is server-side
# only and is used for backend->Privy admin API calls (e.g., fetching a user's
# linked wallets server-side). Never send the secret to the client.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWKS_URL_TEMPLATE=https://auth.privy.io/api/v1/apps/{app_id}/jwks.json
PRIVY_ISSUER=privy.io
# Defaults to PRIVY_APP_ID when empty.
PRIVY_JWT_AUDIENCE=
# If true, protected routes reject unauthenticated requests.
# If false (default), they accept unauthenticated calls — useful for local dev.
PRIVY_REQUIRED=false

# --- scoring ---
DEFAULT_RULESET_VERSION=1
